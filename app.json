{
  "expo": {
    "name": "UKC World",
    "slug": "ukc-world",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ukc",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E293B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.plannivo.ukcworld",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for uploading profile photos and sending images in chat.",
        "NSPhotoLibraryUsageDescription": "Used for selecting profile photos and sending images in chat.",
        "NSFaceIDUsageDescription": "Used for quick and secure sign-in.",
        "NSUserTrackingUsageDescription": "We use anonymous analytics to improve your app experience.",
        "NSCalendarsUsageDescription": "Used to add your lesson bookings to your calendar."
      },
      "associatedDomains": [
        "applinks:plannivo.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E293B"
      },
      "package": "com.plannivo.ukcworld",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "plannivo.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used for selecting profile photos and sending images in chat.",
          "cameraPermission": "Used for uploading profile photos and chat images."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Used for quick and secure sign-in."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0284C7",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "We use anonymous analytics to improve your app experience."
        }
      ],
      "expo-localization",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
