# Reject password login, /auth/register, /api/2fa/verify-2fa, and all authenticated API/WebSocket use of JWTs (emergency lock).
# Prefer project ROOT .env: it overrides backend/.env for this variable (so a template DISABLE_LOGIN=false here does not block root).
# Examples: true | 1 | yes | on
DISABLE_LOGIN=false
# Optional: set in Docker/host only — forces lock on even if .env files disagree.
# DISABLE_LOGIN_FORCE=true

NET_REVENUE_ENABLED=true
SNAPSHOT_CANARY_PCT=50
SIGNATURE_MAX_SIZE_KB=500
SIGNATURE_LOCAL_PREFIX=/uploads/signatures
SIGNATURE_CDN_BASE_URL=
SIGNATURE_BACKUP_ENABLED=true
SIGNATURE_BACKUP_DIR=../backups/signatures
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=50
AUTH_RATE_LIMIT_WINDOW_MS=900000
TWO_FACTOR_RATE_LIMIT_MAX=5
TWO_FACTOR_RATE_LIMIT_WINDOW_MS=300000
PASSWORD_RESET_RATE_LIMIT_MAX=3
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
AUDIT_LOG_RETENTION_YEARS=7

# Google Reviews (Places API) — public endpoint, key stays server-side
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ============================================================
# Email (transactional) — Resend SMTP relay
# ============================================================
# In dev, leave EMAIL_TRANSPORT=stream so emails are logged to stdout instead of sent.
# In production, set EMAIL_TRANSPORT=smtp and supply Resend SMTP credentials below.
EMAIL_TRANSPORT=stream
EMAIL_FROM=Plannivo <no-reply@plannivo.com>
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=

# Frontend URL used to build verification + password-reset links (already used by passwordResetService)
FRONTEND_URL=http://localhost:3000

# ============================================================
# Telegram bot (instructor lesson notifications)
# ============================================================
# Create a bot via @BotFather, paste the token here.
# Leave TELEGRAM_BOT_TOKEN empty to disable Telegram delivery (other channels keep working).
TELEGRAM_BOT_TOKEN=
# Bot username without the @ (used to build deep-link URLs like t.me/<username>?start=<code>)
TELEGRAM_BOT_USERNAME=
# Public HTTPS URL Telegram should POST updates to. In dev use ngrok or similar.
# Example: https://api.plannivo.com/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=
# Secret token Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token header (anti-spoofing).
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# Set TELEGRAM_DEV_POLLING=true to make local dev receive Telegram updates via long polling.
# WARNING: if production uses the same bot token, enabling this WILL break prod (polling
# unregisters the prod webhook). Use a separate dev bot from BotFather, or leave this off.
TELEGRAM_DEV_POLLING=false
