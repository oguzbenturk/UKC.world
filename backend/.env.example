# Reject password login, /auth/register, /api/2fa/verify-2fa, and all authenticated API/WebSocket use of JWTs (emergency lock).
# Prefer project ROOT .env: it overrides backend/.env for this variable (so a template DISABLE_LOGIN=false here does not block root).
# Examples: true | 1 | yes | on
DISABLE_LOGIN=false
# Optional: set in Docker/host only — forces lock on even if .env files disagree.
# DISABLE_LOGIN_FORCE=true

NET_REVENUE_ENABLED=true
SNAPSHOT_CANARY_PCT=50
SIGNATURE_MAX_SIZE_KB=500
SIGNATURE_LOCAL_PREFIX=/uploads/signatures
SIGNATURE_CDN_BASE_URL=
SIGNATURE_BACKUP_ENABLED=true
SIGNATURE_BACKUP_DIR=../backups/signatures
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=50
AUTH_RATE_LIMIT_WINDOW_MS=900000
TWO_FACTOR_RATE_LIMIT_MAX=5
TWO_FACTOR_RATE_LIMIT_WINDOW_MS=300000
PASSWORD_RESET_RATE_LIMIT_MAX=3
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
AUDIT_LOG_RETENTION_YEARS=7
