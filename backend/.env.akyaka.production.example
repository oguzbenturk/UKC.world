# backend/.env.akyaka.production.example
#
# TEMPLATE — copy this to backend/.env.akyaka.production and fill in the real values.
# The real file is gitignored. push-akyaka.js uploads it to the server at deploy time.
#
# Every secret here MUST be different from the corresponding value in backend/.env.production
# (Plannivo's env). push-akyaka.js cross-checks DATABASE_URL and JWT_SECRET and will refuse
# to deploy if they match Plannivo's.
#
# -------------------------------------------------------------------------------
# Database (Akyaka's isolated Postgres container — host hostname is "db" inside
# the akyaka_app-network Docker bridge, port 5432 internally, 5433 on the host).
# -------------------------------------------------------------------------------
DATABASE_URL=postgresql://akyaka:REPLACE_WITH_STRONG_PASSWORD@db:5432/akyaka
POSTGRES_DB=akyaka
POSTGRES_USER=akyaka
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# -------------------------------------------------------------------------------
# Redis (Akyaka's isolated redis container — internal only).
# -------------------------------------------------------------------------------
REDIS_PASSWORD=REPLACE_WITH_DISTINCT_STRONG_PASSWORD

# -------------------------------------------------------------------------------
# Auth secrets — GENERATE FRESH 64-byte hex values. Must differ from Plannivo.
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -------------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_NEW_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_NEW_RANDOM_HEX
SESSION_SECRET=REPLACE_WITH_NEW_RANDOM_HEX

# -------------------------------------------------------------------------------
# URLs / CORS — all point at the Akyaka subdomain.
# -------------------------------------------------------------------------------
NODE_ENV=production
FRONTEND_URL=https://akyaka.plannivo.com
BACKEND_URL=https://akyaka.plannivo.com
PUBLIC_URL=https://akyaka.plannivo.com
CORS_ORIGIN=https://akyaka.plannivo.com

# -------------------------------------------------------------------------------
# Emergency lock + feature flags (carry forward defaults — same app behavior).
# -------------------------------------------------------------------------------
DISABLE_LOGIN=false
NET_REVENUE_ENABLED=true
SNAPSHOT_CANARY_PCT=50

# -------------------------------------------------------------------------------
# Signatures / uploads config (same as Plannivo — not customer-specific).
# -------------------------------------------------------------------------------
SIGNATURE_MAX_SIZE_KB=500
SIGNATURE_LOCAL_PREFIX=/uploads/signatures
SIGNATURE_CDN_BASE_URL=
SIGNATURE_BACKUP_ENABLED=true
SIGNATURE_BACKUP_DIR=../backups/signatures

# -------------------------------------------------------------------------------
# Rate limits (same defaults as Plannivo — tune later per Akyaka traffic).
# -------------------------------------------------------------------------------
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=50
AUTH_RATE_LIMIT_WINDOW_MS=900000
TWO_FACTOR_RATE_LIMIT_MAX=5
TWO_FACTOR_RATE_LIMIT_WINDOW_MS=300000
PASSWORD_RESET_RATE_LIMIT_MAX=3
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
AUDIT_LOG_RETENTION_YEARS=7

# -------------------------------------------------------------------------------
# Third-party integrations — Akyaka will need its own API keys eventually.
# Leave blank for the demo phase; features that call these will degrade gracefully.
# -------------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# -------------------------------------------------------------------------------
# n8n / Kai — NOT deployed for Akyaka (no n8n service in docker-compose.akyaka.yml).
# Leave these empty. Backend features that reach Kai will return graceful no-ops.
# -------------------------------------------------------------------------------
N8N_BASIC_AUTH_PASSWORD=
KAI_AGENT_SECRET=
N8N_API_KEY=

# -------------------------------------------------------------------------------
# Payments (Iyzipay) — blank for demo. Do NOT enable live payments until Akyaka
# has its own merchant account configured.
# -------------------------------------------------------------------------------
# IYZIPAY_API_KEY=
# IYZIPAY_SECRET_KEY=
# IYZIPAY_BASE_URL=
