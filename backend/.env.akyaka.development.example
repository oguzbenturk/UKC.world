# backend/.env.akyaka.development.example
#
# TEMPLATE — copy this to backend/.env.akyaka.development and fill in local dev values.
# The real file is gitignored.
#
# Loaded when the backend is started via `npm run dev:akyaka` (which sets
# BACKEND_ENV_FILE=.env.akyaka.development so server.js and db.js load this file
# instead of backend/.env).
#
# Port/DB values must match docker-compose.akyaka-development.yml exactly:
#   - Postgres: host 127.0.0.1 port 5434, DB akyaka_dev, user akyaka, password "password"
#   - Redis:    host 127.0.0.1 port 6380
#   - Backend:  PORT 4001  (Plannivo UKC dev uses 4000)

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://akyaka:password@localhost:5434/akyaka_dev
POSTGRES_DB=akyaka_dev
POSTGRES_USER=akyaka
POSTGRES_PASSWORD=password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Node / server
# -----------------------------------------------------------------------------
NODE_ENV=development
# Backend listen port — server.js reads BACKEND_API_PORT (not PORT)
BACKEND_API_PORT=4001
BACKEND_API_URL=http://localhost:4001
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:4001
PUBLIC_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# -----------------------------------------------------------------------------
# Auth secrets — development-only. Keep DIFFERENT from Plannivo UKC's dev values.
# Regenerate for local:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=akyaka_dev_jwt_change_me
JWT_REFRESH_SECRET=akyaka_dev_refresh_change_me
SESSION_SECRET=akyaka_dev_session_change_me

# -----------------------------------------------------------------------------
# Emergency lock + feature flags
# -----------------------------------------------------------------------------
DISABLE_LOGIN=false
NET_REVENUE_ENABLED=true
SNAPSHOT_CANARY_PCT=50

# -----------------------------------------------------------------------------
# Signatures / uploads
# -----------------------------------------------------------------------------
SIGNATURE_MAX_SIZE_KB=500
SIGNATURE_LOCAL_PREFIX=/uploads/signatures
SIGNATURE_CDN_BASE_URL=
SIGNATURE_BACKUP_ENABLED=true
SIGNATURE_BACKUP_DIR=../backups/signatures

# -----------------------------------------------------------------------------
# Rate limits
# -----------------------------------------------------------------------------
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=50
AUTH_RATE_LIMIT_WINDOW_MS=900000
TWO_FACTOR_RATE_LIMIT_MAX=5
TWO_FACTOR_RATE_LIMIT_WINDOW_MS=300000
PASSWORD_RESET_RATE_LIMIT_MAX=3
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
AUDIT_LOG_RETENTION_YEARS=7

# -----------------------------------------------------------------------------
# Third-party integrations — blank for local dev
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# -----------------------------------------------------------------------------
# n8n / Kai — not deployed for Akyaka
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_PASSWORD=
KAI_AGENT_SECRET=
N8N_API_KEY=

# -----------------------------------------------------------------------------
# Payments — blank for local dev
# -----------------------------------------------------------------------------
# IYZIPAY_API_KEY=
# IYZIPAY_SECRET_KEY=
# IYZIPAY_BASE_URL=
